# Daemon oc-bridge — roda no PC de casa. Copie para daemon/.env (gitignored).

# Supabase (públicos)
SUPABASE_URL=https://yuzpncdhpmevxanxhgst.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl1enBuY2RocG1ldnhhbnhoZ3N0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE5NjE5NDMsImV4cCI6MjA5NzUzNzk0M30.IBweyLewbIDJZCqVXaTX3qz0pI5F_y31Uem9Cuvzpkc

# Identidade: o daemon entra na MESMA conta que você usa no celular (RLS owner=você).
# No celular você entra por magic link; aqui por email+senha.
OWNER_EMAIL=
OWNER_PASSWORD=

# OpenClaude já buildado (node roda este arquivo)
OPENCLAUDE_BIN=/home/pedrochagas/Documentos/ClaudeClone/openclaude/dist/cli.mjs

# Nome deste daemon (default: hostname) e cwd padrão p/ sessões sem project_path
DAEMON_NAME=
DEFAULT_CWD=/home/pedrochagas/Documentos/Projetos

# Auto-aprovar ferramentas read-only (Read/Grep/Glob/...). Bash/Write sempre pedem no celular.
AUTO_APPROVE_READONLY=true

# (Opcional) Onde salvar os anexos vindos do celular (uma pasta por sessão;
# removida quando a sessão encerra). Default: ~/.oc-bridge/attachments
# ATTACHMENTS_DIR=

# Web Push (VAPID) — daemon envia notificação ao celular (tarefa concluída / aprovação).
# Gere o par com:
#   pnpm --filter @ati/daemon exec node -e 'console.log(require("web-push").generateVAPIDKeys())'
# A PÚBLICA vai p/ a PWA (NEXT_PUBLIC_VAPID_PUBLIC_KEY); a PRIVADA fica SÓ aqui.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:voce@exemplo.com

# --- Auth do OpenClaude: ASSINATURA Claude (OAuth), não API key ---
# Faça UMA vez no PC de casa, após buildar o OpenClaude:
#     node $OPENCLAUDE_BIN setup-token
# Isso loga na sua conta Claude e salva um token de 1 ano em ~/.claude/.credentials.json.
# O daemon roda em modo --print (lê OAuth/keychain) e usa esse token automaticamente.
#
# IMPORTANTE: NÃO defina ANTHROPIC_API_KEY aqui (nem no shell) — se estiver setada,
# o OpenClaude usa a API key (cobrança por API) em vez da assinatura.
#
# (Opcional) usar outro provider via API em vez da assinatura — descomente:
# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=qwen/qwen3-coder:free
